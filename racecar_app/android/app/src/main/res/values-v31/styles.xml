<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash. Paint its background with our splash colour
         so it blends into the in-app animated splash instead of flashing black.
         (The OS always shows the app icon here; matching the colour makes the
         two screens read as one.) -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <!-- Hide the forced icon so only the background colour shows. -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
