<?xml version="1.0" encoding="utf-8"?>
<!-- A fully transparent 1x1 icon. Android 12+ forces an icon onto its system
     splash; using this hides it, so the splash is just our background colour
     and flows straight into the in-app animated splash. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="1dp"
    android:height="1dp"
    android:viewportWidth="1"
    android:viewportHeight="1">
    <path
        android:fillColor="#00000000"
        android:pathData="M0,0h1v1h-1z" />
</vector>
