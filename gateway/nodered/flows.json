    {
        "id": "c39f7a9ead64f0e7",
        "type": "function",
        "z": "5042e23507c6e7ce",
        "name": "function 2",
        "func": "let p = msg.payload;\n\nif (!p || p.time === undefined || !p.playerName) {\n    node.warn(\"Invalid race result payload\");\n    return null;\n}\n\nmsg.measurement = \"race_result\";\n\nmsg.payload = [\n    {\n        race_time: Number(p.time)\n    },\n    {\n        playerName: String(p.playerName),\n        playerColor: String(p.playerColor || \"unknown\")\n    }\n];\n\nreturn msg;",
