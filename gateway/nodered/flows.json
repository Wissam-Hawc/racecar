    {
        "id": "237ed80f86a7aede",
        "type": "function",
        "z": "5042e23507c6e7ce",
        "name": "function 1",
        "func": "\nlet data = msg.payload;\n\nif(!data || !data.car){\n    node.warn(\"INvalide telemetry playload\");\n    return null;\n}\n\n// Example topic: cars/abd/telemetry\nlet parts = msg.topic.split(\"/\");\nlet topicCarId = parts[1] || \"unknown\";\n\nmsg.measurement = \"car_telemetry\";\n\nmsg.payload = [\n    {\n        distance_cm: Number(data.distance_cm || 0),//ultrasonic obstacle distance\n        rssi: Number(data.rssi || 0),//Wi-Fi signal strength\n        odometer_m: Number(data.odometer_m || 0),//estimated distance travelled\n        moving: data.moving === true ? 1 : 0, //wheels moving or not\n        mode_num: data.mode === \"auto\" ? 1 : 0\n\n    },\n    {\n        car: data.car || topicCarId,  //Which car sent the data\n        mode: data.mode || \"unknown\" //manual or auto\n    }\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
